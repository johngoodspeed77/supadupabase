# SupaDupaBase production .env — copy to repo root as .env on the VM
# Generate secrets: openssl rand -base64 32

POSTGRES_USER=supadupabase
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=supadupabase

AUTH_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_ISSUER=https://supadupabase.whitelynx.co.nz
PUBLIC_URL=https://supadupabase.whitelynx.co.nz

ADMIN_EMAILS=your@email.com

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare Zero Trust tunnel token (enables cloudflared profile)
TUNNEL_TOKEN=
