# SupaDupaBase production .env — copy to repo root as .env on the VM
# Generate secrets: openssl rand -base64 32

POSTGRES_USER=supadupabase
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=supadupabase

AUTH_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_ISSUER=https://supadupabase.whitelynx.co.nz
PUBLIC_URL=https://supadupabase.whitelynx.co.nz

ADMIN_EMAILS=your@email.com

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP (Timesheet App weekly email) — Gmail example:
#   1. Enable 2FA on the Google account
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#   3. Use the 16-char app password as SMTP_PASS (not your login password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=johngoodspeed77@gmail.com
SMTP_PASS=
SMTP_FROM=johngoodspeed77@gmail.com
SMTP_SECURE=false

# Cloudflare Zero Trust tunnel token (enables cloudflared profile)
TUNNEL_TOKEN=
