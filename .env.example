# Copy to .env for local development — never commit real values

# Postgres (local docker-compose.dev.yml)
POSTGRES_USER=supadupabase
POSTGRES_PASSWORD=change-me
POSTGRES_DB=supadupabase
DATABASE_URL=postgres://supadupabase:change-me@localhost:5432/supadupabase

# Auth
AUTH_SECRET=local-dev-change-this-to-a-long-random-string
JWT_ISSUER=https://supadupabase.whitelynx.co.nz

# Public URL (production default; override for local if needed)
PUBLIC_URL=https://supadupabase.whitelynx.co.nz

# Service ports (local)
AUTH_PORT=3001
DATA_PORT=3002
ADMIN_PORT=3003
SAMPLE_PORT=5173

# Comma-separated admin emails for /admin/* and POST /auth/api-keys
ADMIN_EMAILS=dev@example.com

# Cloudflare tunnel (production only)
TUNNEL_TOKEN=
