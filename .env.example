# Copy to .env on the VM — never commit real values

# Postgres
POSTGRES_USER=supadupabase
POSTGRES_PASSWORD=change-me
POSTGRES_DB=supadupabase
DATABASE_URL=postgres://supadupabase:change-me@postgres:5432/supadupabase

# Auth
AUTH_SECRET=generate-a-long-random-string
JWT_ISSUER=https://supadupabase.whitelynx.co.nz

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# API keys (generated at runtime; examples only)
# ANON_KEY and SERVICE_ROLE_KEY are per-project in the database

# Public URL (Cloudflare tunnel hostname)
PUBLIC_URL=https://supadupabase.whitelynx.co.nz
